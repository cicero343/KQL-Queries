// Detects Exchange Online mailbox item access from uncommon or untrusted ISP networks.
// Update the TrustedISPs list to match ISP providers commonly used in your environment.

let TrustedISPs = dynamic([
    "BT",
    "Virgin Media",
    "Sky Broadband",
    "TalkTalk",
]);
CloudAppEvents
| where ApplicationId == "20893" // Microsoft Exchange Online
| where ActionType == "MailItemsAccessed"
| where isnotempty(IPAddress)
| where UncommonForUser has "ISP"
| where not(ISP has_any (TrustedISPs))
